#!/usr/bin/env -S /home/shapor/src/skillathon/.venv/bin/python
"""RepoVet SQL query tool — runs DuckDB queries on CSV files.

Usage:
    repovet-query "SELECT * FROM read_csv_auto('file.csv') LIMIT 10"
    repovet-query --markdown "SELECT ..."
    repovet-query --json "SELECT ..."
    repovet-query --csv "SELECT ..."
    repovet-query -f query.sql
"""

import argparse
import json
import sys

import duckdb


def main():
    parser = argparse.ArgumentParser(description="Run DuckDB SQL on CSV files")
    parser.add_argument("sql", nargs="?", help="SQL query")
    parser.add_argument("-f", "--file", help="Read SQL from file")
    parser.add_argument("--markdown", "-m", action="store_true", help="Markdown table output")
    parser.add_argument("--json", "-j", action="store_true", help="JSON output")
    parser.add_argument("--csv", "-c", action="store_true", help="CSV output")
    args = parser.parse_args()

    sql = args.sql
    if args.file:
        with open(args.file) as f:
            sql = f.read()
    if not sql:
        # Read from stdin
        sql = sys.stdin.read()
    if not sql.strip():
        parser.error("Provide SQL as argument, -f file, or via stdin")

    try:
        db = duckdb.connect(":memory:")
        result = db.execute(sql)
        cols = [d[0] for d in result.description]
        rows = result.fetchall()
    except Exception as e:
        print(f"Query error: {e}", file=sys.stderr)
        sys.exit(1)

    if not rows:
        print("(no results)")
        return

    if args.json:
        json.dump([dict(zip(cols, r)) for r in rows], sys.stdout, indent=2, default=str)
        print()
    elif args.csv:
        print(",".join(cols))
        for r in rows:
            print(",".join(str(v) if v is not None else "" for v in r))
    elif args.markdown:
        widths = [max(len(c), max((len(str(r[i]) if r[i] is not None else "") for r in rows), default=0))
                  for i, c in enumerate(cols)]
        print("| " + " | ".join(c.ljust(w) for c, w in zip(cols, widths)) + " |")
        print("|" + "|".join("-" * (w + 2) for w in widths) + "|")
        for r in rows:
            print("| " + " | ".join((str(v) if v is not None else "").ljust(w) for v, w in zip(r, widths)) + " |")
    else:
        widths = [max(len(c), max((len(str(r[i]) if r[i] is not None else "") for r in rows), default=0))
                  for i, c in enumerate(cols)]
        print("  ".join(c.ljust(w) for c, w in zip(cols, widths)))
        print("  ".join("-" * w for w in widths))
        for r in rows:
            print("  ".join((str(v) if v is not None else "").ljust(w) for v, w in zip(r, widths)))


if __name__ == "__main__":
    main()
